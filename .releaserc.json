{
  "branches": ["main"],
  "repositoryUrl": "https://github.com/ByteLandTechnology/jellyfin-agent-cli.git",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/release/build-binaries.mjs ${nextRelease.version} && node scripts/release/sync-platform-packages.mjs ${nextRelease.version}",
        "publishCmd": "node scripts/release/publish-npm-packages.mjs ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false,
        "pkgRoot": "npm/main"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "Cargo.toml",
          "Cargo.lock",
          "npm/main/package.json"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "dist/*.tar.gz", "label": "Archive" },
          { "path": "dist/*.sha256", "label": "Checksum" }
        ]
      }
    ]
  ]
}
